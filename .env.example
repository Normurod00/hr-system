APP_NAME="HR-BRB"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=hr_brb
DB_USERNAME=postgres
DB_PASSWORD=your-strong-db-password

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=hr_brb_

# ============================================
# Reverb WebSocket
# ============================================
REVERB_APP_ID=hr-brb
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${APP_URL}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=your-strong-redis-password
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hr@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================
# AI Server Configuration
# ============================================
AI_SERVER_URL=http://ai:8095
AI_SERVER_TIMEOUT=30

# ============================================
# Employee Portal Settings
# ============================================
EMPLOYEE_PORTAL_ENABLED=true
EMPLOYEE_KPI_CACHE_TTL=1800

# ============================================
# KPI API Integration (PLACEHOLDER)
# ============================================
# Location for future KPI API integration
# When ready, set KPI_API_ENABLED=true and configure credentials
KPI_API_ENABLED=false
KPI_API_BASE_URL=https://kpi.example.com/api/v1
KPI_API_TOKEN=
KPI_API_TIMEOUT=30
KPI_API_RETRY=3

# ============================================
# Pulse API Integration (PLACEHOLDER)
# ============================================
PULSE_API_ENABLED=false
PULSE_API_BASE_URL=https://pulse.example.com/api/v1
PULSE_API_TOKEN=
PULSE_API_TIMEOUT=30

# ============================================
# Smart Office Integration (PLACEHOLDER)
# ============================================
SMART_OFFICE_API_ENABLED=false
SMART_OFFICE_API_BASE_URL=https://smartoffice.example.com/api
SMART_OFFICE_API_TOKEN=
SMART_OFFICE_API_TIMEOUT=30

# ============================================
# iABS Integration (PLACEHOLDER)
# ============================================
IABS_API_ENABLED=false
IABS_API_BASE_URL=https://iabs.example.com/api
IABS_API_TOKEN=
IABS_API_TIMEOUT=60
